# Ola Maps (masjid + islamic institution finder)
VITE_OLA_MAPS_API_KEY=
VITE_OLA_STYLE_JSON_URL=
VITE_OLA_PLACES_AUTOCOMPLETE_URL=
VITE_OLA_PLACES_TEXTSEARCH_URL=
VITE_OLA_PLACES_NEARBY_ADVANCED_URL=
VITE_OLA_PLACES_DETAILS_URL=
VITE_OLA_PLACES_DETAILS_ADVANCED_URL=
